# Calendly - used by Book Demo page "Pick a time now" embed. Your Calendly scheduling URL (e.g. https://calendly.com/your-username)
VITE_CALENDLY_URL=

# Google Tag / GA4 - for analytics and Google Ads conversion tracking. Get from GA4 Admin > Data Streams, or from Google Ads > Tools > Conversions when linked.
VITE_GA4_MEASUREMENT_ID=

# Contact form email delivery - create an API key at https://resend.com and verify the sender domain/email.
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CONTACT_FROM_EMAIL=info@domi-clear.com
CONTACT_TO_EMAIL=info@domi-clear.com
